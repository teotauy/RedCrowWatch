# RedCrowWatch Environment Variables
# Copy this file to .env and fill in your actual values

# ── Reolink Camera ────────────────────────────────────────────────────────────
REOLINK_IP=192.168.1.xxx          # camera's local IP address
REOLINK_USER=admin                # default Reolink username
REOLINK_PASS=your_camera_password

# ── YouTube Live Stream ───────────────────────────────────────────────────────
# Get stream key from: YouTube Studio → Go Live → Stream
YOUTUBE_STREAM_KEY=xxxx-xxxx-xxxx-xxxx-xxxx

# ── Streaming Options ─────────────────────────────────────────────────────────
STREAM_WIDTH=1280
STREAM_HEIGHT=720
STREAM_FPS=25
DETECT_EVERY=3     # run YOLO every N frames (lower = more CPU)
PASS_AUDIO=1       # 1 = pass camera audio, 0 = silence
YOLO_MODEL=yolov8n.pt   # yolov8n.pt (fast) or yolov8s.pt (more accurate)

# ── Twitter / X (Phase 2) ─────────────────────────────────────────────────────
TWITTER_API_KEY=your_api_key_here
TWITTER_API_SECRET=your_api_secret_here
TWITTER_ACCESS_TOKEN=your_access_token_here
TWITTER_ACCESS_TOKEN_SECRET=your_access_token_secret_here

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
